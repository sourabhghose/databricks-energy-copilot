    classDef dltStyle     fill:#4527A0,stroke:#311B92,color:#ffffff,rx:6
    classDef goldStyle    fill:#F57F17,stroke:#E65100,color:#ffffff,rx:6
    classDef warehStyle   fill:#E65100,stroke:#BF360C,color:#ffffff,rx:6
    classDef lakeStyle    fill:#1B5E20,stroke:#1B5E20,color:#ffffff,rx:6
    classDef snapStyle    fill:#004D40,stroke:#00251A,color:#ffffff,rx:6
    classDef beStyle      fill:#263238,stroke:#102027,color:#ffffff,rx:6
    classDef feStyle      fill:#37474F,stroke:#102027,color:#ffffff,rx:6

    class NW,OE,OM,AP sourceStyle
    class BR,SI,GO dltStyle
    class T1,T2,T3,T4,T5,T6 goldStyle
    class WH warehStyle
    class ST,PG lakeStyle
    class SG,SC snapStyle
    class RT beStyle
    class UI feStyle

    style SRC  fill:#1565C022,stroke:#1565C0,color:#1565C0
    style DLT  fill:#4527A022,stroke:#4527A0,color:#4527A0
    style UC   fill:#F57F1722,stroke:#F57F17,color:#E65100
    style SQLW fill:#E6510022,stroke:#E65100,color:#BF360C
    style LB   fill:#1B5E2022,stroke:#1B5E20,color:#1B5E20
    style SNAP fill:#004D4022,stroke:#004D40,color:#004D40
    style BE   fill:#26323822,stroke:#263238,color:#263238
    style FE   fill:#37474F22,stroke:#37474F,color:#37474F
