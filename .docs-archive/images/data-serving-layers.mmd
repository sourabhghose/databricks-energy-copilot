---
title: Energy Copilot — Data Serving Layers
---
flowchart LR
    %% ── Data Sources ──────────────────────────────────────────────
    subgraph SRC["Data Sources"]
        direction TB
        NW["NEMWEB\n(AEMO 5-min)"]
        OE["OpenElectricity\nAPI"]
        OM["Open-Meteo\n(Weather)"]
        AP["APVI\n(Solar)"]
    end

    %% ── DLT Pipelines ─────────────────────────────────────────────
    subgraph DLT["DLT Pipelines"]
        direction TB
        BR["Bronze\n(Raw Ingest)"]
        SI["Silver\n(Cleaned)"]
        GO["Gold\n(Aggregated)"]
        BR --> SI --> GO
    end

    %% ── Unity Catalog Gold ────────────────────────────────────────
    subgraph UC["Unity Catalog  —  Gold Tables  (Delta Lake)"]
        direction TB
        T1["nem_prices_5min"]
        T2["nem_generation_by_fuel"]
        T3["nem_interconnectors"]
        T4["price_forecasts / demand_forecasts"]
        T5["asx_futures_eod / gas_hub_prices"]
        T6["dashboard_snapshots\n(CDF enabled)"]
    end

    %% ── Serving Path A: SQL Warehouse ─────────────────────────────
    subgraph SQLW["SQL Warehouse"]
        direction TB
        WH["Databricks\nSQL Warehouse\n⏱ 400–1000 ms"]
    end

    %% ── Serving Path B: Lakebase ──────────────────────────────────
    subgraph LB["Lakebase / Postgres"]
        direction TB
        ST["Synced Tables\n(Delta → Postgres)"]
        PG["Lakebase Instance\nenergy-copilot-db\n⏱ 10–38 ms"]
        ST --> PG
    end

    %% ── Snapshot Path ─────────────────────────────────────────────
    subgraph SNAP["Snapshot Layer"]
        direction TB
        SG["Snapshot Generator\n(every 5 min)"]
        SC["dashboard_snapshots\nPre-computed JSON\n⏱ sub-10 ms"]
        SG --> SC
    end

    %% ── Backend ───────────────────────────────────────────────────
    subgraph BE["FastAPI Backend"]
        direction TB
        RT["13 Router Modules\n~385 real-data endpoints"]
    end

    %% ── Frontend ──────────────────────────────────────────────────
    subgraph FE["React Frontend"]
        direction TB
        UI["475 Pages\nDashboards · Copilot · Genie"]
    end

    %% ── Edges: Sources → DLT ──────────────────────────────────────
    NW & OE & OM & AP --> BR

    %% ── Edges: DLT → Unity Catalog ────────────────────────────────
    GO --> T1 & T2 & T3 & T4 & T5 & T6

    %% ── Edges: Gold → SQL Warehouse ───────────────────────────────
    T1 & T2 & T3 & T4 & T5 --> WH

    %% ── Edges: Gold → Synced Tables ───────────────────────────────
    T1 & T2 & T3 & T5 --> ST

    %% ── Edges: Gold → Snapshot Generator ─────────────────────────
    T6 --> SG

    %% ── Edges: Snapshot → Lakebase ────────────────────────────────
    SC --> PG

    %% ── Edges: Serving Layers → Backend ───────────────────────────
    WH --> RT
    PG --> RT

    %% ── Edges: Backend → Frontend ─────────────────────────────────
    RT --> UI

    %% ── Styling ───────────────────────────────────────────────────
